{
  "name": "neodeskpet-electron",
  "productName": "NeoDeskPet",
  "private": true,
  "version": "0.21.0",
  "description": "AI-powered Live2D desktop companion with chat, memory, tools, and MCP integrations.",
  "author": "nishichengju",
  "homepage": "https://github.com/nishichengju/NeoDeskPet",
  "repository": {
    "type": "git",
    "url": "https://github.com/nishichengju/NeoDeskPet.git"
  },
  "license": "AGPL-3.0-only",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "set ELECTRON_RUN_AS_NODE=&& vite",
    "dev:reset": "powershell -ExecutionPolicy Bypass -File scripts/dev-reset.ps1",
    "brand:assets": "node scripts/generate-brand-assets.mjs",
    "build": "npm run brand:assets && tsc && vite build && node scripts/build-release.mjs",
    "build:unpacked": "npm run brand:assets && tsc && vite build && node scripts/build-release.mjs --win --dir",
    "build:full": "npm run brand:assets && tsc && vite build && node scripts/build-release.mjs --full",
    "postinstall": "electron-builder install-app-deps && node scripts/install-playwright-browser.mjs",
    "rebuild:native": "electron-builder install-app-deps",
    "playwright:install": "node scripts/install-playwright-browser.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "ui:baseline": "vite build && node scripts/capture-ui-baseline.mjs",
    "media:smoke": "node scripts/verify-local-media.mjs",
    "ipc:smoke": "node scripts/verify-ipc-security.mjs",
    "installer:smoke": "node scripts/verify-windows-installer.mjs",
    "installer:smoke:full": "node scripts/verify-windows-installer.mjs --full",
    "release:report": "node scripts/report-release-size.mjs",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1",
    "@pixi/unsafe-eval": "^6.5.10",
    "better-sqlite3": "^12.5.0",
    "electron-store": "^10.0.0",
    "pixi-live2d-display": "0.4.0",
    "pixi.js": "6.5.10",
    "playwright-core": "1.61.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "zod": "^4.3.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "resedit": "^2.0.3",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^1.6.1"
  }
}
